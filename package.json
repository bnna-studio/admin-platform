{
  "name": "admin-platform",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "dashboard",
    "cms-site"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:studio": "cd backend && npx prisma studio"
  }
}