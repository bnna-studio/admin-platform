// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────────────────
// Multi-tenant Core Models
// ──────────────────────────────────────────────────────────────────────────

/// Represents a client (tenant) in the system
model Organization {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  users     User[]
  sites     Site[]

  @@map("organizations")
}

/// User belongs to an organization
model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  displayName     String?
  role            String   @default("viewer") // owner | editor | viewer
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@map("users")
}

/// A website owned by an organization
model Site {
  id              String   @id @default(cuid())
  name            String
  domain          String
  apiKey          String   @unique @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  listings        Listing[]
  seoSettings     SEOSettings[]

  @@index([organizationId])
  @@map("sites")
}

// ──────────────────────────────────────────────────────────────────────────
// Content Models
// ──────────────────────────────────────────────────────────────────────────

/// Listings for a site (e.g. real estate, products, etc.)
model Listing {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  price       Float?
  images      Json?    // Array of image URLs
  status      String   @default("draft") // draft | published
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([siteId])
  @@index([status])
  @@map("listings")
}

/// SEO metadata for site pages
model SEOSettings {
  id              String   @id @default(cuid())
  pagePath        String   // "/" | "/about" | "/contact"
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  canonicalUrl    String?
  siteId          String
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([siteId, pagePath])
  @@index([siteId])
  @@map("seo_settings")
}