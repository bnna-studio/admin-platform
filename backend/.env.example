# Postgres connection string. On Railway this is auto-injected when you
# attach the Postgres plugin (Railway exposes it as DATABASE_URL).
DATABASE_URL="postgresql://user:password@localhost:5432/admin_platform?schema=public"

# Long random string used to sign JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="your-secret-key-here-change-in-production"

# Comma-separated list of allowed dashboard origins (no trailing slash).
# Examples:
#   CORS_ORIGINS="https://admin.moaicreative.com"
#   CORS_ORIGINS="https://admin.moaicreative.com,https://admin-platform.up.railway.app"
# Falls back to FRONTEND_URL, then http://localhost:5173 in dev.
CORS_ORIGINS="http://localhost:5173"

# Port the server listens on. Railway injects PORT automatically; leave
# unset on Railway and the server will use what Railway provides.
PORT=3000

NODE_ENV="development"
